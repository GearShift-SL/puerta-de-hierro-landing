---
import { Image } from 'astro:assets';
import mainBath from '~/assets/images/renders/main-bath.jpg';
import secondaryBath from '~/assets/images/renders/secondary-bath.jpg';
import kitchen2 from '~/assets/images/renders/kitchen-2.jpg';
import mainBedroom2 from '~/assets/images/renders/main-bredroom-2.jpg';
import secondaryBedroom from '~/assets/images/renders/secondary-bredroom.jpg';
---

<section class="py-20 md:py-28 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8 scroll-animate">
      <p class="text-muted text-lg">Descubre cada espacio en detalle</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
      <div class="scroll-animate" data-delay="100">
        <Image
          src={mainBath}
          alt="Baño principal de lujo"
          class="w-full aspect-4/3 object-cover rounded-2xl shadow-lg"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Baño principal</p>
      </div>
      <div class="scroll-animate" data-delay="200">
        <Image
          src={secondaryBath}
          alt="Baño secundario"
          class="w-full aspect-4/3 object-cover rounded-2xl shadow-lg"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Baño secundario</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="scroll-animate" data-delay="100">
        <Image
          src={kitchen2}
          alt="Cocina de diseño con isla"
          class="w-full aspect-4/3 object-cover rounded-2xl shadow-lg"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Cocina</p>
      </div>
      <div class="scroll-animate" data-delay="200">
        <Image
          src={mainBedroom2}
          alt="Dormitorio principal"
          class="w-full aspect-4/3 object-cover rounded-2xl shadow-lg"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Dormitorio principal</p>
      </div>
      <div class="scroll-animate" data-delay="300">
        <Image
          src={secondaryBedroom}
          alt="Dormitorio secundario"
          class="w-full aspect-4/3 object-cover rounded-2xl shadow-lg"
          widths={[400, 700]}
          sizes="(max-width: 768px) 100vw, 33vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Dormitorio secundario</p>
      </div>
    </div>
  </div>
</section>
