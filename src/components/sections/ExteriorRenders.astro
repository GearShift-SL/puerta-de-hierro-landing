---
import { Image } from 'astro:assets';
import streetEntrance from '~/assets/images/renders/street-entrance.jpg';
import gardenEntrance from '~/assets/images/renders/garden-entrance.jpg';
import garageEntrance from '~/assets/images/renders/garage-entrance.jpg';
import pool from '~/assets/images/renders/pool.jpg';
import pergola from '~/assets/images/renders/pergola.jpg';
---

<section class="py-20 md:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-8 scroll-animate">
      <p class="text-muted text-lg">Exteriores diseñados para la vida al aire libre</p>
    </div>

    <!-- Top row: street entrance (2/3) + garden/garage stacked (1/3) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
      <div class="md:col-span-2 scroll-animate">
        <Image
          src={streetEntrance}
          alt="Acceso principal desde la calle"
          class="w-full h-full object-cover rounded-2xl shadow-lg"
          style="aspect-ratio: 4/3; min-height: 100%;"
          widths={[600, 900, 1200]}
          sizes="(max-width: 768px) 100vw, 66vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Acceso desde la calle</p>
      </div>
      <div class="flex flex-col gap-4">
        <div class="scroll-animate" data-delay="100">
          <Image
            src={gardenEntrance}
            alt="Acceso al jardín"
            class="w-full object-cover rounded-2xl shadow-lg"
            style="aspect-ratio: 4/3;"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 33vw"
            loading="lazy"
          />
          <p class="text-muted text-sm mt-3 text-center">Acceso al jardín</p>
        </div>
        <div class="scroll-animate" data-delay="200">
          <Image
            src={garageEntrance}
            alt="Entrada al garaje"
            class="w-full object-cover rounded-2xl shadow-lg"
            style="aspect-ratio: 4/3;"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 33vw"
            loading="lazy"
          />
          <p class="text-muted text-sm mt-3 text-center">Entrada al garaje</p>
        </div>
      </div>
    </div>

    <!-- Bottom row: pool (1/2) + pergola (1/2) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="scroll-animate" data-delay="100">
        <Image
          src={pool}
          alt="Piscina privada"
          class="w-full object-cover rounded-2xl shadow-lg"
          style="aspect-ratio: 4/3;"
          widths={[400, 700, 900]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Piscina privada</p>
      </div>
      <div class="scroll-animate" data-delay="200">
        <Image
          src={pergola}
          alt="Pérgola exterior"
          class="w-full object-cover rounded-2xl shadow-lg"
          style="aspect-ratio: 4/3;"
          widths={[400, 700, 900]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <p class="text-muted text-sm mt-3 text-center">Pérgola exterior</p>
      </div>
    </div>
  </div>
</section>
